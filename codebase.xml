 67:       await _verifyConnectivityAndAppCheck();
 68: 
 69:       // Sign out of any existing sessions first
 70:       await _googleSignIn.signOut();
 71: 
 72:       // Begin interactive sign in process
 73:       final GoogleSignInAccount? googleUser = await _googleSignIn.signIn();
 74: 
 75:       if (googleUser == null) {
 76:         _logger.warning('Google sign in cancelled by user');
 77:         return null;
 78:       }
