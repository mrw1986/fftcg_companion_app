19:   Timer? _emailVerificationTimer;
20: 
21:   @override
22:   void initState() {
23:     super.initState();
24:     _logger.info('AuthWrapper initialized');
25:     _startEmailVerificationCheck();
26:   }
27: 
28:   void _startEmailVerificationCheck() {
29:     _emailVerificationTimer?.cancel();
30:     _emailVerificationTimer = Timer.periodic(
31:       const Duration(seconds: 5),
32:       (_) {
33:         final authState = ref.read(authNotifierProvider);
34:         final user = authState.user;
35: 
36:         // Only check if we have a non-guest authenticated user who needs verification
37:         if (authState.status == AuthStatus.authenticated &&
38:             user != null &&
39:             !user.isGuest &&
40:             !user.isEmailVerified &&
41:             user.email != null) {
42:           ref.read(authNotifierProvider.notifier).checkEmailVerification();
43:         }
44:       },
45:     );
46:   }
47: 
48:   @override
49:   void dispose() {
50:     _emailVerificationTimer?.cancel();
51:     super.dispose();
52:   }
53: 
54:   @override
55: Widget build(BuildContext context) {
56:   final authState = ref.watch(authNotifierProvider);
57:   
58:   _logger.info('Auth status: ${authState.status}');
59: 
60:   switch (authState.status) {
61:     case AuthStatus.authenticated:
62:     case AuthStatus.guest:
63:       // Both authenticated and guest users see the CardsScreen
64:       return const CardsScreen();
65:       
66:     case AuthStatus.unauthenticated:
67:     case AuthStatus.error:
68:       return const LoginScreen();
69:       
70:     case AuthStatus.loading:
71:     case AuthStatus.initial:
72:       return const Scaffold(
73:         body: Center(
74:           child: CircularProgressIndicator(),
75:         ),
76:       );
77:   }
78: }
79: }
