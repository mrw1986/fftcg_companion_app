<file path="lib/core/logging/logger_service.dart">
  1: import 'dart:io';
  2: import 'package:flutter/foundation.dart';
  3: import 'package:logging/logging.dart';
  4: import 'package:path_provider/path_provider.dart';
  5: import 'package:share_plus/share_plus.dart';
  6: 
  7: class LoggerService {
  8:   static final LoggerService _instance = LoggerService._internal();
  9:   static const String _logFileName = 'fftcg_companion.log';
 10:   static const String _errorLogFileName = 'fftcg_companion_error.log';
 11:   static const int _maxLogSizeBytes = 5 * 1024 * 1024; // 5MB
 12:   static const int _maxBackupFiles = 3;
 13: 
 14:   final Logger _logger = Logger('FFTCGCompanion');
 15:   File? _logFile;
 16:   File? _errorLogFile;
 17: 
 18:   factory LoggerService() {
 19:     return _instance;
 20:   }
 21: 
 22:   LoggerService._internal() {
 23:     _initializeLogger();
 24:   }
 25: 
 26:   Future<void> _initializeLogger() async {
 27:     final Directory appDocDir = await getApplicationDocumentsDirectory();
 28:     _logFile = File('${appDocDir.path}/$_logFileName');
 29:     _errorLogFile = File('${appDocDir.path}/$_errorLogFileName');
 30: 
 31:     // Perform log rotation on startup
 32:     await _rotateLogsIfNeeded();
 33: 
 34:     Logger.root.level = Level.ALL;
 35:     Logger.root.onRecord.listen((record) async {
 36:       final logMessage =
 37:           '${record.time}: ${record.level.name}: ${record.message}';
 38: 
 39:       if (kDebugMode) {
 40:         debugPrint(logMessage);
 41:       }
 42: 
 43:       if (_logFile != null) {
 44:         await _logFile!.writeAsString(
 45:           '$logMessage\n',
 46:           mode: FileMode.append,
 47:         );
 48:         await _rotateLogsIfNeeded();
 49:       }
 50: 
 51:       // Write severe logs to error log file
 52:       if (record.level >= Level.SEVERE && _errorLogFile != null) {
 53:         final errorMessage = '''
 54: ${record.time}: ${record.level.name}: ${record.message}
 55: ${record.error ?? ''}
 56: ${_formatStackTrace(record.stackTrace)}
 57: ----------------------------------------
 58: ''';
 59:         await _errorLogFile!.writeAsString(
 60:           errorMessage,
 61:           mode: FileMode.append,
 62:         );
 63:       }
 64:     });
 65:   }
 66: 
 67:   Future<void> _rotateLogsIfNeeded() async {
 68:     if (_logFile == null || !await _logFile!.exists()) return;
 69: 
 70:     final fileSize = await _logFile!.length();
 71:     if (fileSize > _maxLogSizeBytes) {
 72:       for (var i = _maxBackupFiles - 1; i >= 0; i--) {
 73:         final backupFile = File('${_logFile!.path}.$i');
 74:         if (await backupFile.exists()) {
 75:           if (i == _maxBackupFiles - 1) {
 76:             await backupFile.delete();
 77:           } else {
 78:             await backupFile.rename('${_logFile!.path}.${i + 1}');
 79:           }
 80:         }
 81:       }
 82: 
 83:       await _logFile!.rename('${_logFile!.path}.0');
 84:       _logFile = File(_logFile!.path);
 85:       await _logFile!.create();
 86:     }
 87:   }
 88: 
 89:   String _formatStackTrace(StackTrace? stackTrace) {
 90:     if (stackTrace == null) return '';
 91: 
 92:     return stackTrace.toString().split('\n').map((line) {
 93:       line = line.trim();
 94:       if (line.startsWith('#')) {
 95:         // Format stack trace lines for better readability
 96:         return '  $line';
 97:       }
 98:       return line;
 99:     }).join('\n');
100:   }
101: 
102:   void info(String message) => _logger.info(message);
103:   void warning(String message) => _logger.warning(message);
104: 
105:   void error(String message, [Object? error, StackTrace? stackTrace]) {
106:     _logger.severe(message, error, stackTrace);
107:   }
108: 
109:   void exception(String message, Exception exception,
110:       [StackTrace? stackTrace]) {
111:     final formattedMessage = '''
112: Exception: $message
113: Type: ${exception.runtimeType}
114: Details: ${exception.toString()}''';
115: 
116:     _logger.severe(
117:         formattedMessage, exception, stackTrace ?? StackTrace.current);
118:   }
119: 
120:   Future<void> shareLogs() async {
121:     final logs = <XFile>[];
122: 
123:     if (_logFile != null && await _logFile!.exists()) {
124:       logs.add(XFile(_logFile!.path));
125:     }
126: 
127:     if (_errorLogFile != null && await _errorLogFile!.exists()) {
128:       logs.add(XFile(_errorLogFile!.path));
129:     }
130: 
131:     if (logs.isNotEmpty) {
132:       await Share.shareXFiles(
133:         logs,
134:         subject: 'FFTCG Companion Logs',
135:       );
136:     }
137:   }
138: 
139:   Future<String> getLogs({bool errorLogsOnly = false}) async {
140:     final StringBuffer buffer = StringBuffer();
141: 
142:     if (!errorLogsOnly && _logFile != null && await _logFile!.exists()) {
143:       buffer.writeln('=== General Logs ===');
144:       buffer.writeln(await _logFile!.readAsString());
145:     }
146: 
147:     if (_errorLogFile != null && await _errorLogFile!.exists()) {
148:       buffer.writeln('=== Error Logs ===');
149:       buffer.writeln(await _errorLogFile!.readAsString());
150:     }
151: 
152:     return buffer.toString().trim().isNotEmpty
153:         ? buffer.toString()
154:         : 'No logs available';
155:   }
156: 
157:   Future<void> clearLogs({bool errorLogsOnly = false}) async {
158:     if (!errorLogsOnly && _logFile != null && await _logFile!.exists()) {
159:       await _logFile!.writeAsString('');
160:     }
161: 
162:     if (_errorLogFile != null && await _errorLogFile!.exists()) {
163:       await _errorLogFile!.writeAsString('');
164:     }
165:   }
166: }
</file>

