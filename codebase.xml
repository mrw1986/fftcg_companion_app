337:   Future<void> _verifyConnectivityAndAppCheck() async {
338:     final connectivityResult = await Connectivity().checkConnectivity();
339:     if (connectivityResult.contains(ConnectivityResult.none)) {
340:       throw CustomAuthException(
341:         code: 'no-connection',
342:         message: 'No internet connection available',
343:       );
344:     }
345: 
346:     if (!kDebugMode) {
347:       try {
348:         final token =
349:             await FirebaseAppCheck.instance.getToken(true).timeout(_timeout);
350:         if (token == null) {
351:           throw CustomAuthException(
352:             code: 'app-check-failed',
353:             message: 'Failed to verify app authenticity',
354:           );
355:         }
356:       } catch (e) {
357:         _logger.error('App Check verification failed', e);
358:         throw CustomAuthException(
359:           code: 'app-check-failed',
360:           message: 'Failed to verify app authenticity',
361:         );
362:       }
363:     }
364:   }
