<file path="lib/features/auth/providers/auth_notifier.dart">
  1: // lib/features/auth/providers/auth_notifier.dart
  2: 
  3: import 'dart:async';
  4: import 'package:flutter_riverpod/flutter_riverpod.dart';
  5: import '../../../core/logging/logger_service.dart';
  6: import '../repositories/auth_repository.dart';
  7: import '../enums/auth_status.dart';
  8: import 'auth_state.dart';
  9: import '../services/auth_service.dart';
 10: 
 11: class AuthNotifier extends StateNotifier<AuthState> {
 12:   final AuthRepository _authRepository;
 13:   final LoggerService _logger;
 14:   StreamSubscription? _authStateSubscription;
 15: 
 16:   AuthNotifier({
 17:     required AuthRepository authRepository,
 18:     LoggerService? logger,
 19:   })  : _authRepository = authRepository,
 20:         _logger = logger ?? LoggerService(),
 21:         super(AuthState()) {
 22:     _initialize();
 23:   }
 24: 
 25:   void _initialize() {
 26:     _authStateSubscription?.cancel();
 27:     _authStateSubscription = _authRepository.authStateChanges.listen(
 28:       (user) async {
 29:         if (user != null && user.isGuest) {
 30:           state = state.copyWith(status: AuthStatus.guest, user: user);
 31:         } else if (user != null) {
 32:           state = state.copyWith(status: AuthStatus.authenticated, user: user);
 33:         } else {
 34:           state =
 35:               state.copyWith(status: AuthStatus.unauthenticated, user: null);
 36:         }
 37:       },
 38:       onError: (error, stackTrace) {
 39:         state = state.copyWith(
 40:             status: AuthStatus.error, errorMessage: error.toString());
 41:       },
 42:     );
 43:   }
 44: 
 45:   Future<void> signInWithGoogle() async {
 46:     try {
 47:       state = state.copyWith(status: AuthStatus.loading);
 48:       _logger.info('Attempting Google sign in');
 49: 
 50:       await _authRepository.signInWithGoogle();
 51: 
 52:       // State will be updated by the auth state listener
 53:       _logger.info('Google sign in completed successfully');
 54:     } catch (e, stackTrace) {
 55:       _logger.error('Error signing in with Google', e, stackTrace);
 56:       state = state.copyWith(
 57:         status: AuthStatus.error,
 58:         errorMessage: 'Failed to sign in with Google',
 59:       );
 60:     }
 61:   }
 62: 
 63:   Future<void> signInWithEmailPassword(String email, String password) async {
 64:     try {
 65:       state = state.copyWith(status: AuthStatus.loading);
 66:       _logger.info('Attempting email/password sign in');
 67: 
 68:       await _authRepository.signInWithEmailPassword(email, password);
 69: 
 70:       // State will be updated by the auth state listener
 71:       _logger.info('Email/password sign in completed successfully');
 72:     } catch (e, stackTrace) {
 73:       _logger.error('Error signing in with email/password', e, stackTrace);
 74:       state = state.copyWith(
 75:         status: AuthStatus.error,
 76:         errorMessage: 'Invalid email or password',
 77:       );
 78:     }
 79:   }
 80: 
 81:   Future<void> registerWithEmailPassword(
 82:     String email,
 83:     String password,
 84:     String displayName,
 85:   ) async {
 86:     try {
 87:       state = state.copyWith(status: AuthStatus.loading);
 88:       _logger.info('Attempting user registration');
 89: 
 90:       await _authRepository.registerWithEmailPassword(
 91:         email,
 92:         password,
 93:         displayName,
 94:       );
 95: 
 96:       // State will be updated by the auth state listener
 97:       _logger.info('User registration completed successfully');
 98:     } catch (e, stackTrace) {
 99:       _logger.error('Error registering with email/password', e, stackTrace);
100:       state = state.copyWith(
101:         status: AuthStatus.error,
102:         errorMessage: 'Failed to create account',
103:       );
104:     }
105:   }
106: 
107:   Future<void> signInAsGuest() async {
108:     try {
109:       state = state.copyWith(status: AuthStatus.loading);
110:       _logger.info('Attempting guest sign in');
111: 
112:       final guestUser = await _authRepository.signInAsGuest();
113: 
114:       if (guestUser != null) {
115:         state = state.copyWith(
116:           status: AuthStatus.guest,
117:           user: guestUser,
118:           errorMessage: null,
119:         );
120:         _logger.info('Guest sign in completed successfully: ${guestUser.id}');
121:       } else {
122:         throw CustomAuthException(
123:           code: 'guest-session-failed',
124:           message: 'Failed to create guest session',
125:         );
126:       }
127:     } catch (e, stackTrace) {
128:       _logger.error('Error signing in as guest', e, stackTrace);
129:       state = state.copyWith(
130:         status: AuthStatus.error,
131:         errorMessage: e is CustomAuthException
132:             ? e.message
133:             : 'Failed to continue as guest',
134:       );
135:     }
136:   }
137: 
138:   Future<void> signOut() async {
139:     try {
140:       state = state.copyWith(status: AuthStatus.loading);
141:       _logger.info('Attempting sign out');
142: 
143:       await _authRepository.signOut();
144: 
145:       // State will be updated by the auth state listener
146:       _logger.info('Sign out completed successfully');
147:     } catch (e, stackTrace) {
148:       _logger.error('Error signing out', e, stackTrace);
149:       state = state.copyWith(
150:         status: AuthStatus.error,
151:         errorMessage: 'Failed to sign out',
152:       );
153:     }
154:   }
155: 
156:   Future<void> sendEmailVerification() async {
157:     try {
158:       _logger.info('Sending email verification');
159:       await _authRepository.sendEmailVerification();
160:       _logger.info('Email verification sent successfully');
161:     } catch (e, stackTrace) {
162:       _logger.error('Error sending email verification', e, stackTrace);
163:       state = state.copyWith(
164:         status: AuthStatus.error,
165:         errorMessage: 'Failed to send verification email',
