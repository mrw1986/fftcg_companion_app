 16: void main() async {
 17:   WidgetsFlutterBinding.ensureInitialized();
 18:   final logger = LoggerService();
 19: 
 20:   try {
 21:     // Initialize SharedPreferences
 22:     final sharedPrefs = await SharedPreferences.getInstance();
 23: 
 24:     // Create ProviderContainer with overrides
 25:     final container = ProviderContainer(
 26:       overrides: [
 27:         sharedPreferencesProvider.overrideWithValue(sharedPrefs),
 28:       ],
 29:     );
 30: 
 31:     // Initialize Firebase and App Check
 32:     await _initializeFirebase(logger);
 33: 
 34:     // Run the app with ProviderScope
 35:     runApp(
 36:       UncontrolledProviderScope(
 37:         container: container,
 38:         child: const FFTCGCompanionApp(),
 39:       ),
 40:     );
 41:   } catch (e, stackTrace) {
 42:     logger.error('Failed to initialize app', e, stackTrace);
 43:     runApp(
 44:       MaterialApp(
 45:         theme: AppTheme.darkTheme,
 46:         home: _buildErrorScreen(e.toString(), () {
 47:           main();
 48:         }),
 49:       ),
 50:     );
 51:   }
 52: }
 53: 
 54: Future<void> _initializeFirebase(LoggerService logger) async {
 55:   try {
 56:     // Check connectivity first
 57:     final connectivity = Connectivity();
 58:     final connectivityResult = await connectivity.checkConnectivity();
 59:     if (connectivityResult.contains(ConnectivityResult.none)) {
 60:       logger.warning('No network connectivity available');
 61:     }
 62: 
 63:     // Initialize Firebase
 64:     await Firebase.initializeApp(
 65:       options: DefaultFirebaseOptions.currentPlatform,
 66:     );
 67: 
 68:     // Initialize App Check with retry mechanism
 69:     if (!kIsWeb && !kDebugMode) {
 70:       // Only enable App Check in release mode
 71:       await FirebaseAppCheck.instance.activate(
 72:         androidProvider: AndroidProvider.playIntegrity,
 73:         appleProvider: AppleProvider.appAttest,
 74:       );
 75:     }
 76: 
 77:     logger.info('Firebase initialized successfully');
 78:   } catch (e, stackTrace) {
 79:     logger.error('Firebase initialization failed', e, stackTrace);
 80:     rethrow;
 81:   }
 82: }
