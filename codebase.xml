366:   String _getReadableAuthError(String code) {
367:     switch (code) {
368:       case 'user-not-found':
369:         return 'No account exists with this email. Please create an account first.';
370:       case 'wrong-password':
371:         return 'Incorrect password. Please try again or use Reset Password.';
372:       case 'invalid-email':
373:         return 'Please enter a valid email address.';
374:       case 'user-disabled':
375:         return 'This account has been disabled.';
376:       case 'email-already-in-use':
377:         return 'An account already exists with this email. Please sign in instead.';
378:       case 'operation-not-allowed':
379:         return 'This operation is not allowed';
380:       case 'weak-password':
381:         return 'Please enter a stronger password';
382:       case 'network-request-failed':
383:         return 'Network error. Please check your connection';
384:       case 'too-many-requests':
385:         return 'Too many attempts. Please try again later';
386:       case 'timeout':
387:         return 'Operation timed out. Please try again';
388:       case 'app-check-failed':
389:         return 'App verification failed. Please ensure you\'re using an official version';
390:       case 'no-connection':
391:         return 'No internet connection available';
392:       default:
393:         return 'Authentication failed. Please try again';
394:     }
395:   }
396: }
